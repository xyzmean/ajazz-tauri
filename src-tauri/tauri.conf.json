{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AJAZZ Tauri Driver",
  "version": "0.1.0",
  "identifier": "com.ajazz.tauri.driver",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run stage-helper && npm run dev",
    "beforeBuildCommand": "npm run stage-helper && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AJAZZ Driver",
        "width": 1100,
        "height": 720,
        "minWidth": 360,
        "minHeight": 320,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage", "dmg", "app"],
    "externalBin": [
      "binaries/ajazz-helperd"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
